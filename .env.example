# Copy to .env and adjust per environment. Never commit the real .env.

# --- Flask application ---
FLASK_APP=api.app
FLASK_ENV=development
PORT=5001

# --- Model artifacts ---
# Directory holding the serialised pipeline artifacts (clusterer, regressor,
# classifier, encoders, scalers). Absolute path inside the container,
# relative path for local development.
MODEL_DIR=./models

# --- API metadata ---
API_VERSION=1.0.0

# --- CORS ---
# Comma-separated list of allowed origins. Use * for local development only.
CORS_ORIGINS=*

# --- Frontend (configured separately in frontend/.env for Vite) ---
# VITE_API_URL=http://localhost:5001
